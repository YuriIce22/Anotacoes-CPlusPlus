{

    int qtd=0;
    float aux=0, notas;

    while(true){
        
        cout << "Digite as notas: ";
        cin >> notas;

        if(notas < 0){
            cout << "Nota inválida." << endl;
            continue;
        }
        
        if(notas > 10){
            cout << "Nota inválida. Encerrando o programa." << endl;
            break;
        }   
    
        qtd++;
        aux += notas;
    }
    
    cout << "A média aritmética das notas é: " << aux/qtd;

 
    return 0;
}


































