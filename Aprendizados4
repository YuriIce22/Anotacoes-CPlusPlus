#include <iostream>
#include <cstdlib>
#include <ctime>
#include <cmath>
using namespace std;


float coin(float n1);


int main()
{

	float n1;

	cout << "Insira o número de lançamentos de uma moeda em um cara ou coroa: ";
	cin >> n1;

    coin(n1);


}


float coin(float n1){
    
    float cara=0, coroa=0;

    unsigned seed = time(0);
    srand(seed);

    for(int i=0; i<n1; i++){
        if(rand()%2==0){
            coroa++;
        }else{
            cara++;
        }
    }
    
    cout << "O número de caras foi: " << cara << ". E o número de coroa foi: " << coroa << endl;
    cout << "O % de cara foi: " << (cara/n1)*100 << "%. E a % de coroa foi: " << (coroa/n1)*100 << "%." << endl;
    
    
    return 0;

}


