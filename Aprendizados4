#include <iostream>
#include <cstdlib>
#include <ctime>
#include <cmath>
using namespace std;


void maior(float n1, float n2, float n3);
void menor(float n1, float n2, float n3);


int main()
{

	float n1, n2, n3;

	cout << "Insira o primeiro número: ";
	cin >> n1;
	cout << "Insira o segundo número: ";
	cin >> n2;
	cout << "Insira o terceiro número: ";
	cin >> n3;

    maior(n1, n2, n3);
    menor(n1, n2, n3);


}


void maior(float n1, float n2, float n3) {
	float aux=-999999999999;


	while((n1>aux)&&(n2>aux)&&(n3>aux)) {
		if(n1>aux) {
			aux=n1;
		}
		if(n2>aux) {
			aux=n2;
		}
		if(n3>aux) {
			aux=n3;
		}

		break;
	}
	
	    cout << "O maior número é: " << aux << endl;

}

void menor (float n1, float n2, float n3) {
	float aux=999999999;

	while((n1<aux)&&(n2<aux)&&(n3<aux)) {
		if(n1<aux) {
			aux=n1;
		}
		if(n2<aux) {
			aux=n2;
		}
		if(n3<aux) {
			aux=n3;
		}

		break;
	}

    cout << "O menor: " << aux << endl;

}

























