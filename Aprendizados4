#include <iostream>
#include <cstdlib>
#include <ctime>
#include <cmath>
using namespace std;


float hipo(float lad1, float lad2);

int main()
{
    float lado1, lado2;
    
    cout << "Insira o primeiro lado do triangulo retangulo: ";
    cin >> lado1;
    cout << "Insira o segundo lado do triangulo retangulo: ";
    cin >> lado2;
    hipo(lado1, lado2);
    cout << "A hipotenusa é: " << hipo(lado1, lado2);
    

    return 0;
}


float hipo(float lad1, float lad2){
    
    return sqrt((lad1 * lad1) + (lad2 * lad2));

}


