#include <iostream>
using namespace std;

int main()
{

    int aux, num1, lim;
    
    cout << "Digite um número inteiro: ";
    cin >> num1;
    cout << "Digite um número limite para essa tabuada: ";
    cin >> lim;
    
    for(aux=1; aux <= lim; aux++){
        cout << "A conta de: " << num1 << " x " << aux << " = " << num1*aux << endl;
    }

    return 0;
}


