#include <iostream>
#include <iomanip>

using namespace std;

int main()
{

    int num;
    
    while(true){
        cout << "Digite um número: ";
        cin >> num;
        

          if(num==0){
              break;
          }
          
        for(int i=1; i<=10; i++){
          cout << i << " ";
        }
        
        cout << num*num << endl;
    }
    
    cout << "O laço foi encerrado!";

    

    return 0;
}


