#include <iostream>
#include <cmath>
#include <random>

int const COLUMN = 3;
int const ROW = 3;

void show(int [ROW][COLUMN]);

int main()
{

    int matriz[ROW][COLUMN] = { {1,2,3}, {4,5,6}, {7,8,9} };
    
    show(matriz);
    
    return 0;
}

void show(int matriz[ROW][COLUMN])
{
    
    for(int i=0; i<ROW; i++){
        for(int j=0; j<COLUMN; j++){
         std::cout << matriz[i][j] << "  ";
        }
        std::cout << std::endl;
    }
    
}



