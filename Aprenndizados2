#include <iostream>
using namespace std;

int main()
{

    int tri1, tri2, tri3;

    
    cout << "Insira o primeiro lado de um triangulo: ";
    cin >> tri1;
    cout << "Insira o segundo lado de um triangulo: ";
    cin >> tri2;
    cout << "Insira o terceiro lado de um triangulo: ";
    cin >> tri3;
    
    if(tri1 == tri2 && tri2 == tri3){
        cout << "O triangulo tem 3 lados iguais. Ele é Equilátero." << endl;
    }
    
    else if((tri1 == tri2 && tri1 != tri3) || (tri1 == tri3 && tri3 != tri2) || (tri2 == tri3 && tri1 != tri2)) {
        cout << "O triangulo tem 2 lados iguais. Ele é Isósceles.";
    }
    
    else{
        cout << "O triangulo tem 3 lados diferentes. Ele é Escaleno.";
    }

    return 0;
}


