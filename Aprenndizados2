#include <iostream>
using namespace std;

int main()
{

    int num1, num2, resul, opcao;
    int num3, num4;
    
    cout << "Insira um número inteiro: ";
    cin >> num1;
    cout << "Insira outro número inteiro: ";
    cin >> num2;
    
    cout << "Digite uma operação: \n";
    cout << "[1. Soma]\n";
    cout << "[2. Subtração]\n";
    cout << "[3. Multiplicação]\n";
    cout << "[4. Divisão]\n";
    cout << "[5. Resto de Divisão]\n";
    cout << "Digite uma opção [Número de 1 a 5]: ";
    cin >> opcao;

    switch(opcao){
        case 1:
        resul = num1 + num2;
        cout << "O resultado de " << num1 << " + " << num2 << " é " << resul;
        break;
        
        case 2:
        resul = num1 - num2;
        cout << "O resultado de " << num1 << " - " << num2 << " é " << resul;
        break;
        
        case 3:
        resul = num1 * num2;
        cout << "O resultado de " << num1 << " x " << num2 << " é " << resul;
        break;
        
        case 4:
        resul = num1 / num2;
        cout << "O resultado de " << num1 << " / " << num2 << " é " << resul;
        break;
        
        case 5:
        resul = num3 % num4;
        cout << "O resultado dos restos de " << num3 << " / " << num4 << " é " << resul;
        break;
    }

    return 0;
}


