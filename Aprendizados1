#include <iostream>
#include <iomanip>
using namespace std;

int main()
{
    string nomes;
    float num1, num2, num3, num4, sum1, sum2, sum3;
        
    //Nome    
    cout << "Digite seu nome: ";
    getline (cin, nomes);
    cout << "Seu nome é " << nomes << "!" << endl << endl;
    
    //Dobrar
    cout << "Coloque um número para ser dobrado: ";
    cin >> num1;
    sum1 = num1 * 2;
    cout << "O número é: " << num1 << ". Seu número dobrado é: " << sum1 << endl << endl;
    
    //Área Quadrado
    cout << "Insira o tamanho de um lado de um quadrado para descobrir sua área: ";
    cin >> num2;
    sum2 = num2 * num2;
    cout << "A lateral do quadrado é: " << num2 << ". A área do quadrado é: " << sum2 << endl << endl;
    
    //Área Triangulo
    cout << "Insira o tamanho de dois lados de um triangulo (base -> aperte enter -> insira altura -> enter) para descobrir sua área: ";
    cin >> num3 >> num4;
    sum3 = (num3 * num4)/2;
    cout << "Os dois lados do triangulo é: " << num3 << " e " << num4 << ". A área do triangulo é: " << sum3 << endl << endl;
    

    return 0;
}
    
    
    
    
    
    
    
    
    
    
    
    
    
    